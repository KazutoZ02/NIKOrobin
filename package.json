{
  "name": "royals-paradise",
  "version": "1.0.0",
  "description": "Royal's Paradise - Gaming & Digital Services Platform",
  "main": "server/index.js",
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "dev": "concurrently \"npm run server\" \"cd client && npm run dev\"",
    "build": "cd client && npm run build",
    "start": "NODE_ENV=production node server/index.js",
    "server": "node server/index.js"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "connect-mongo": "^5.1.0",
    "express-rate-limit": "^7.1.5",
    "crypto": "^1.0.1",
    "node-fetch": "^2.7.0",
    "discord.js": "^14.14.1",
    "fast-xml-parser": "^4.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
